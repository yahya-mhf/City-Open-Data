# =============================================================================
# Urban Pulse - Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in your values before running the project.
#   cp .env.example .env
# =============================================================================

# --- TimescaleDB / PostgreSQL -----------------------------------------------
DATABASE_URL=postgresql+asyncpg://sc_user:sc_password@timescaledb:5432/smart_city

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ ---------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- MinIO (S3-compatible object storage) -----------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=sc_access_key
MINIO_SECRET_KEY=sc_secret_key
MINIO_BUCKET=smart-city
MINIO_SECURE=false

# --- JWT Authentication -----------------------------------------------------
JWT_SECRET=super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App Configuration -------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Internal API Secret (for inter-service auth) ---------------------------
INTERNAL_SECRET=your-internal-secret-here

# --- AI / Groq (for intelligence features) ----------------------------------
GROQ_API_KEY=your_groq_api_key_here

# --- Simulator --------------------------------------------------------------
SIMULATOR_INTERVAL_SECONDS=5
SIMULATOR_SENSOR_COUNT=20
SIMULATOR_BATCH_SIZE=10
SIMULATOR_REALISTIC_TIME=true

# --- Web (Next.js) ----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
API_INTERNAL_URL=http://api:8000/api/v1
